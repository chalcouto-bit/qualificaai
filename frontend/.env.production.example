# QualificaAI Frontend — Variáveis de Ambiente de Produção
# No EasyPanel, configure as variáveis VITE_* como "Build Args" (embutidas no build)
# e a BACKEND_URL como variável de ambiente de runtime (usada pelo Nginx).
# NÃO faça commit deste arquivo com valores reais preenchidos.

# ── Build Args (VITE_*) — configure em Build Args no EasyPanel ──────────────
# URL pública da Supabase (pode ser exposta no frontend)
VITE_SUPABASE_URL=https://mmywrkrmwichahpegshv.supabase.co

# Anon Key pública da Supabase (segura para o frontend)
# Encontre em: Supabase Dashboard > Project Settings > API > anon/public
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# Prefixo das chamadas de API no Vite (não precisa mudar)
VITE_API_URL=/api

# ── Runtime Env (Nginx) — configure como variável de ambiente no EasyPanel ───
# URL pública do backend (com https, sem barra no final)
# Exemplo: https://api.seudominio.com
BACKEND_URL=https://api.seudominio.com
