# QualificaAI Frontend — Variáveis de Ambiente de Produção
# No EasyPanel, configure TODAS as variáveis abaixo como "Build Args" (seção Build).
# NÃO faça commit deste arquivo com valores reais preenchidos.

# ── Build Args (VITE_*) — configure no EasyPanel como Build Args ─────────────

# URL pública da Supabase
VITE_SUPABASE_URL=https://mmywrkrmwichahpegshv.supabase.co

# Anon Key pública da Supabase (segura para o frontend)
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# URL COMPLETA do backend (com /api no final, SEM barra no fim)
# ⚠️ CRÍTICO: o frontend chama o backend diretamente com esta URL
# Exemplo: https://vibe-code-backend.uswynw.easypanel.host/api
VITE_API_URL=https://SEU_BACKEND.easypanel.host/api
