# QualificaAI Backend — Variáveis de Ambiente de Produção
# No EasyPanel: cole cada linha como variável de ambiente no painel do app.
# NÃO faça commit deste arquivo com valores reais preenchidos.

# ── Supabase ──────────────────────────────────────────────────
# URL pública do projeto Supabase (igual no frontend)
SUPABASE_URL=https://mmywrkrmwichahpegshv.supabase.co

# Service Role Key (SECRETA — nunca exponha no frontend)
# Encontre em: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=SEU_SERVICE_ROLE_KEY_AQUI

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────
# URL pública do frontend no EasyPanel (com https)
# Exemplo: https://app.seudominio.com
FRONTEND_URL=https://app.seudominio.com
